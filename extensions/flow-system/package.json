{
  "name": "@codewithkenzo/pi-dispatch",
  "version": "0.1.1",
  "description": "Queue and run Pi tasks with reusable profiles",
  "type": "module",
  "main": "./dist/index.js",
  "extensions": [
    "./dist/index.js"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "bun build ./index.ts --outfile ./dist/index.js --target node",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "pi",
    "pi-agent",
    "pi-coding-agent",
    "pi-agent-core",
    "dispatch",
    "task-queue",
    "agent-orchestration",
    "subagents",
    "vfs",
    "plan-mode",
    "workflow"
  ],
  "dependencies": {
    "@mariozechner/pi-tui": "^0.63.1",
    "@sinclair/typebox": "^0.34.0",
    "effect": "4.0.0-beta.48"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@types/bun": "1.3.12",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*"
  }
}
