{
  "name": "@codewithkenzo/pi-blitz",
  "version": "0.1.0-alpha.3",
  "description": "Pi extension wrapping the blitz AST-aware fast-edit CLI",
  "type": "module",
  "main": "./dist/index.js",
  "extensions": [
    "./dist/index.js"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./index.ts --outfile ./dist/index.js --target node && mkdir -p ./dist/skills && cp -R ./skills/pi-blitz ./dist/skills/pi-blitz",
    "tsc": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "pi",
    "pi-agent",
    "pi-coding-agent",
    "pi-agent-core",
    "ast",
    "tree-sitter",
    "fast-edit",
    "blitz"
  ],
  "dependencies": {
    "@codewithkenzo/blitz": "0.1.0-alpha.3",
    "@sinclair/typebox": "^0.34.0",
    "effect": "4.0.0-beta.48"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@types/bun": "1.3.12",
    "bun-types": "1.3.12",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-agent-core": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@codewithkenzo/blitz-darwin-arm64": "0.1.0-alpha.0",
    "@codewithkenzo/blitz-darwin-x64": "0.1.0-alpha.0",
    "@codewithkenzo/blitz-linux-x64-musl": "0.1.0-alpha.0",
    "@codewithkenzo/blitz-linux-arm64-musl": "0.1.0-alpha.0",
    "@codewithkenzo/blitz-windows-x64": "0.1.0-alpha.0"
  }
}
